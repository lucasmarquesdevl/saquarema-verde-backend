# ============================================================
# .env.example — Saquarema Verde Backend
# ============================================================
# INSTRUÇÃO: Copie este arquivo para um novo arquivo chamado .env
# e preencha com as suas credenciais locais.
# NUNCA faça commit do arquivo .env real no repositório!
# ============================================================

# --- SERVIDOR ---
PORT=8080

# --- SEGURANÇA (JWT) ---
# Use uma string longa, aleatória e secreta. Nunca use a de exemplo abaixo em produção.
JWT_SECRET=sua_chave_secreta_muito_longa_e_aleatoria_aqui

# --- BANCO DE DADOS (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=saquarema_verde

# --- CORS (origens permitidas) ---
# Em desenvolvimento local, use * para liberar tudo.
# Em produção, coloque o domínio do seu site: https://seusite.com
CORS_ORIGIN=*
